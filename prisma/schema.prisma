generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SeasonStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RegistrationStatus {
  PENDING
  ACTIVE
  CANCELLED
}

enum PointSource {
  EVENT
  MANUAL
  BONUS
  PENALTY
}

model User {
  id                    Int                  @id @default(autoincrement())
  telegramId            BigInt               @unique
  username              String?
  firstName             String?
  lastName              String?
  languageCode          String?
  activeWalletId        Int?                 @unique
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  lastSeenAt            DateTime?
  activeWallet          Wallet?              @relation("UserActiveWallet", fields: [activeWalletId], references: [id])
  wallets               Wallet[]             @relation("UserWallets")
  seasonRegistrations   SeasonRegistration[]
  seasonPoints          SeasonPoint[]
  seasonStats           UserSeasonStats[]
  userBadges            UserBadge[]
}

model Wallet {
  id                   Int                  @id @default(autoincrement())
  address              String               @unique
  label                String?
  isActive             Boolean              @default(false)
  userId               Int?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User?                @relation("UserWallets", fields: [userId], references: [id], onDelete: SetNull)
  activeForUser        User?                @relation("UserActiveWallet")
  seasonRegistrations  SeasonRegistration[]
  seasonPoints         SeasonPoint[]
  detectedEvents       DetectedEvent[]
  scannerCursor        WalletScannerCursor?

  @@index([userId])
  @@index([userId, isActive])
}

model WalletScannerCursor {
  id            Int       @id @default(autoincrement())
  walletId      Int       @unique
  lastSlot      BigInt?
  snapshot      Json?
  scannedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  wallet        Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Season {
  id                   Int                  @id @default(autoincrement())
  slug                 String               @unique
  name                 String
  description          String?
  status               SeasonStatus         @default(DRAFT)
  startsAt             DateTime
  endsAt               DateTime
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  registrations        SeasonRegistration[]
  points               SeasonPoint[]
  detectedEvents       DetectedEvent[]
  userStats            UserSeasonStats[]
  userBadges           UserBadge[]
}

model SeasonRegistration {
  id            Int                @id @default(autoincrement())
  userId        Int
  walletId      Int
  seasonId      Int
  status        RegistrationStatus @default(ACTIVE)
  registeredAt  DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  season        Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@unique([walletId, seasonId])
  @@index([seasonId, status])
}

model SeasonPoint {
  id               Int            @id @default(autoincrement())
  seasonId         Int
  userId           Int
  walletId         Int?
  detectedEventId  Int?
  points           Int
  category         String
  source           PointSource    @default(EVENT)
  reason           String
  metadata         Json?
  createdAt        DateTime       @default(now())
  season           Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet           Wallet?        @relation(fields: [walletId], references: [id], onDelete: SetNull)
  detectedEvent    DetectedEvent? @relation(fields: [detectedEventId], references: [id], onDelete: SetNull)

  @@index([seasonId, userId])
  @@index([seasonId, category])
  @@index([walletId, createdAt])
}

model DetectedEvent {
  id             Int            @id @default(autoincrement())
  txHash         String
  eventType      String
  walletId       Int
  seasonId       Int?
  blockNumber    BigInt?
  logIndex       Int?
  occurredAt     DateTime
  rawData        Json?
  createdAt      DateTime       @default(now())
  wallet         Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  season         Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  seasonPoints   SeasonPoint[]

  @@unique([txHash, eventType, walletId])
  @@index([seasonId, occurredAt])
  @@index([walletId, occurredAt])
}

model UserSeasonStats {
  id              Int       @id @default(autoincrement())
  userId          Int
  seasonId        Int
  totalPoints     Int       @default(0)
  rank            Int?
  eventsCount     Int       @default(0)
  badgesCount     Int       @default(0)
  lastEventAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  season          Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, rank])
}

model Badge {
  id            Int        @id @default(autoincrement())
  code          String     @unique
  name          String
  description   String?
  icon          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userBadges    UserBadge[]
}

model UserBadge {
  id          Int       @id @default(autoincrement())
  userId      Int
  badgeId     Int
  seasonId    Int?
  reason      String?
  awardedAt   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  season      Season?   @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId, seasonId])
  @@index([seasonId, awardedAt])
}
